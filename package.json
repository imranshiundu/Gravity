{
  "name": "gravity-workspace",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "web:dev": "pnpm --dir apps/web dev",
    "web:build": "pnpm --dir apps/web build",
    "web:typecheck": "pnpm --dir apps/web typecheck",
    "core:dev": "pnpm --dir services/grav-core dev",
    "core:build": "pnpm --dir services/grav-core build",
    "contracts:build": "pnpm --dir packages/grav-contracts build",
    "typecheck": "pnpm --dir apps/web typecheck && pnpm --dir packages/grav-contracts build && pnpm --dir services/grav-core build"
  },
  "packageManager": "pnpm@10.6.5"
}
